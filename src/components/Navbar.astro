---
---
<nav class="navbar">
  <a href="#" class="nav-logo">OURA & CO.</a>

  <ul class="nav-links">
    <li><a href="#" class="active">HOME</a></li>
    <li><a href="#">WORKS</a></li>
    <li><a href="#">STUDIO</a></li>
    <li><a href="#">PROCESS</a></li>
    <li><a href="#">GALLERY</a></li>
  </ul>

  <a href="#" class="nav-cta">
    GET IN TOUCH
    <span class="cta-circle"></span>
  </a>

  <button class="mobile-menu-toggle" id="mobileMenuOpen" aria-label="Open menu" aria-expanded="false">
    <span class="hb-line"></span>
    <span class="hb-line hb-short"></span>
  </button>
</nav>

<!-- Mobile overlay lives outside navbar → no stacking context trap -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <div class="mm-inner">

    <header class="mm-header">
      <span class="mm-brand">OURA & CO.</span>
      <button class="mm-close" id="mobileMenuClose" aria-label="Close menu">CLOSE</button>
    </header>

    <div class="mm-info">
      <div class="mm-info-row">
        <span class="mm-info-label">Studio</span>
        <span class="mm-info-value">OURA & CO.</span>
      </div>
      <div class="mm-info-row">
        <span class="mm-info-label">Location</span>
        <span class="mm-info-value">Mumbai, India</span>
      </div>
      <div class="mm-info-row">
        <span class="mm-info-label">Discipline</span>
        <span class="mm-info-value">Interior Architecture</span>
      </div>
      <div class="mm-info-row">
        <span class="mm-info-label">Est.</span>
        <span class="mm-info-value">2019</span>
      </div>
    </div>

    <nav class="mm-nav">
      <a href="#" class="mm-nav-item is-current">
        <span class="mn-num">01</span>
        <span class="mn-label">Home</span>
        <svg class="mn-arrow" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#" class="mm-nav-item">
        <span class="mn-num">02</span>
        <span class="mn-label">Works</span>
        <svg class="mn-arrow" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#" class="mm-nav-item">
        <span class="mn-num">03</span>
        <span class="mn-label">Studio</span>
        <svg class="mn-arrow" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#" class="mm-nav-item">
        <span class="mn-num">04</span>
        <span class="mn-label">Process</span>
        <svg class="mn-arrow" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="#" class="mm-nav-item">
        <span class="mn-num">05</span>
        <span class="mn-label">Contact</span>
        <svg class="mn-arrow" viewBox="0 0 12 12" fill="none">
          <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>

  </div>
</div>

<style>
  /* ────────────────────────────────────────
     NAVBAR (desktop)
  ──────────────────────────────────────── */
  .navbar {
    position: absolute;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 26px var(--px);
    opacity: 0;
    transform: translateY(-8px);
    animation: navIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) 3.2s forwards;
  }

  @keyframes navIn {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Logo ── */
  .nav-logo {
    font-weight: 700;
    font-size: 19px;
    letter-spacing: -0.02em;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .nav-logo:hover { opacity: 0.7; }

  /* ── Links ── */
  .nav-links {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 10px;
  }

  .nav-links a {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.09em;
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 3px;
    transition: color 0.3s ease;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-links a:hover,
  .nav-links a.active { color: #fff; }

  .nav-links a:hover::after,
  .nav-links a.active::after { transform: scaleX(1); }

  /* ── CTA ── */
  .nav-cta {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.09em;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.3s ease;
  }
  .nav-cta:hover { color: #fff; }

  .cta-circle {
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.5);
    flex-shrink: 0;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .nav-cta:hover .cta-circle {
    background: #fff;
    border-color: #fff;
  }

  /* ── Hamburger toggle (mobile only) ── */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 200;
    position: relative;
  }

  .hb-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: #fff;
    border-radius: 1px;
    transition: opacity 0.2s ease, width 0.3s ease;
  }

  .hb-short {
    width: 60%;
  }

  .mobile-menu-toggle:hover .hb-short {
    width: 100%;
  }

  /* ────────────────────────────────────────
     MOBILE MENU OVERLAY
  ──────────────────────────────────────── */
  .mobile-menu {
    display: none; /* hidden on desktop */
    position: fixed;
    inset: 0;
    z-index: 1500;
    background: #f2efe9;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    overflow-x: hidden;
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  .mm-inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 0 24px 40px;
  }

  /* ── Menu header ── */
  .mm-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    flex-shrink: 0;
    border-bottom: 1px solid rgba(26, 23, 20, 0.10);
  }

  .mm-brand {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #1a1714;
  }

  .mm-close {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.10em;
    color: #1a1714;
    background: none;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
    padding: 4px 0;
    transition: opacity 0.2s ease;
  }
  .mm-close:hover { opacity: 0.5; }

  /* ── Info block ── */
  .mm-info {
    padding: 36px 0 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .mm-info-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mm-info-label {
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(26, 23, 20, 0.45);
    text-transform: uppercase;
  }

  .mm-info-value {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #1a1714;
  }

  /* ── Nav items ── */
  .mm-nav {
    display: flex;
    flex-direction: column;
  }

  .mm-nav-item {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 18px 0;
    border-top: 1px solid rgba(26, 23, 20, 0.10);
    text-decoration: none;
    color: #1a1714;
    transition: opacity 0.2s ease;
  }

  .mm-nav-item:last-child {
    border-bottom: 1px solid rgba(26, 23, 20, 0.10);
  }

  .mm-nav-item.is-current {
    color: rgba(26, 23, 20, 0.35);
  }

  .mm-nav-item:not(.is-current):hover {
    opacity: 0.6;
  }

  .mn-num {
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: inherit;
    min-width: 28px;
    flex-shrink: 0;
  }

  .mn-label {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: inherit;
    flex: 1;
  }

  .mn-arrow {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: inherit;
    opacity: 0.6;
  }

  /* ────────────────────────────────────────
     RESPONSIVE
  ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .navbar {
      padding: 20px var(--px);
    }

    .nav-logo {
      font-size: 16px;
    }

    .nav-links,
    .nav-cta {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 18px var(--px);
    }

    .nav-logo {
      font-size: 14px;
    }

    .mm-inner {
      padding: 0 20px 36px;
    }

    .mn-label {
      font-size: 20px;
    }

    .mm-nav-item {
      padding: 16px 0;
      gap: 16px;
    }
  }

  @media (max-width: 360px) {
    .navbar {
      padding: 16px var(--px);
    }

    .nav-logo {
      font-size: 13px;
    }

    .mobile-menu-toggle {
      width: 24px;
      height: 24px;
      gap: 5px;
    }

    .mm-inner {
      padding: 0 16px 32px;
    }

    .mm-brand {
      font-size: 12px;
    }

    .mm-info {
      padding: 28px 0 32px;
      gap: 12px;
    }

    .mm-info-value {
      font-size: 13px;
    }

    .mn-num {
      font-size: 12px;
      min-width: 24px;
    }

    .mn-label {
      font-size: 18px;
    }

    .mn-arrow {
      width: 15px;
      height: 15px;
    }

    .mm-nav-item {
      padding: 14px 0;
      gap: 14px;
    }
  }
</style>

<script>
  function initNav(): void {
    const openBtn  = document.getElementById('mobileMenuOpen') as HTMLButtonElement | null;
    const closeBtn = document.getElementById('mobileMenuClose') as HTMLButtonElement | null;
    const menu     = document.getElementById('mobileMenu') as HTMLElement | null;

    if (!openBtn || !closeBtn || !menu) return;

    function openMenu(): void {
      menu!.classList.add('is-open');
      menu!.setAttribute('aria-hidden', 'false');
      openBtn!.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu(): void {
      menu!.classList.remove('is-open');
      menu!.setAttribute('aria-hidden', 'true');
      openBtn!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    // Close on nav link click
    menu.querySelectorAll('.mm-nav-item').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
