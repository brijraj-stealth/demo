---
import Navbar from './Navbar.astro';

interface Slide {
  src: string;
  alt: string;
}

interface Props {
  eyebrow?:     string;
  titleLines?:  string[];
  scrollHint?:  string;
  loaderLogo?:  string;
  loaderLabel?: string;
  slides?:      Slide[];
}

const {
  eyebrow    = 'Whatever you feel',
  titleLines = ['WE DESIGN', 'THE FEELING', 'OF YOU'],
  scrollHint = '( SCROLL DOWN )',
  loaderLogo  = 'OURA & CO.',
  loaderLabel = 'Crafting your space',
  slides = [
    { src: '/asset 3.avif',  alt: 'Villa Aurelia interior' },
    { src: '/asset 4.avif',  alt: 'Meridian Retreat living room' },
    { src: '/asset 5.avif',  alt: 'Casa Lumina dining space' },
    { src: '/asset 7.avif',  alt: 'The Serai House entrance' },
    { src: '/asset 8.avif',  alt: 'Terrace Pavilion exterior' },
    { src: '/asset 9.avif',  alt: 'Kala Residence bedroom' },
    { src: '/asset 10.avif', alt: 'Studio Vale workspace' },
    { src: '/asset 12.avif', alt: 'Grove House kitchen' },
    { src: '/asset 13.avif', alt: 'Alta Villa terrace' },
    { src: '/asset 15.avif', alt: 'Pine Lodge interior' },
    { src: '/asset 17.avif', alt: 'Reva Court living area' },
    { src: '/asset 18.avif', alt: 'Soleil Manor study' },
    { src: '/asset 19.avif', alt: 'Dusk Pavilion exterior' },
    { src: '/asset 21.avif', alt: 'Haven Estate entrance' },
  ],
} = Astro.props;
---

<!-- ════ LOADER ════ -->
<div class="loader" id="loader" aria-hidden="true">
  <div class="loader-inner">
    <span class="loader-logo">{loaderLogo}</span>
    <div class="loader-track">
      <div class="loader-fill"></div>
    </div>
    <span class="loader-label">{loaderLabel}</span>
  </div>
</div>

<!-- ════ HERO ════ -->
<section class="hero" id="hero" aria-label="Hero slideshow">
  <Navbar />

  <div class="slider" id="slider" aria-hidden="true">
    {slides.map((slide, i) => (
      <div class="slide">
        <img
          src={slide.src}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding={i === 0 ? 'sync' : 'async'}
          draggable="false"
        />
      </div>
    ))}
  </div>

  <div class="overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="title">
      {titleLines.map((line, i) => (
        <>
          {line}
          {i < titleLines.length - 1 && <br />}
        </>
      ))}
    </h1>
  </div>

  <p class="scroll-hint" aria-hidden="true">{scrollHint}</p>
</section>

<style>
/* ─────────────────────────────────
   DESIGN TOKENS
───────────────────────────────── */
:where(.loader, .hero) {
  /* Easings */
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-in:     cubic-bezier(0.4, 0, 0.2, 1);
  --ease-fill:   cubic-bezier(0.4, 0, 0.15, 1);

  /* Z-index scale */
  --z-overlay: 3;
  --z-content: 10;
  --z-loader:  2000;

  /* Color channels — usage: rgb(var(--c-dark) / 0.5) */
  --c-dark:  6 4 2;
  --c-white: 255 255 255;
}

/* ─────────────────────────────────
   KEYFRAMES
───────────────────────────────── */
@keyframes riseIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fillBar {
  to { width: 100%; }
}

/* ─────────────────────────────────
   LOADER
───────────────────────────────── */
.loader {
  position: fixed;
  inset: 0;
  z-index: var(--z-loader);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #0c0a08;
  transition:
    opacity    1s var(--ease-in),
    visibility 0s linear 1s;
}

.loader.fade-out {
  opacity: 0;
  visibility: hidden;
}

.loader-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.loader-logo {
  opacity: 0;
  color: rgb(var(--c-white));
  font-weight: 600;
  font-size: 17px;
  letter-spacing: 0.22em;
  transform: translateY(12px);
  animation: riseIn 0.9s var(--ease-spring) 0.3s forwards;
}

.loader-track {
  width: 160px;
  height: 1px;
  overflow: hidden;
  background: rgb(var(--c-white) / 0.1);
  opacity: 0;
  animation: riseIn 0.6s ease 0.8s forwards;
}

.loader-fill {
  height: 100%;
  background: linear-gradient(90deg, rgb(var(--c-white) / 0.4), rgb(var(--c-white)));
  animation: fillBar 1.8s var(--ease-fill) 1s forwards;
}

.loader-label {
  opacity: 0;
  color: rgb(var(--c-white) / 0.35);
  font-weight: 300;
  font-size: 10px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  animation: riseIn 0.6s ease 1s forwards;
}

/* ─────────────────────────────────
   HERO
───────────────────────────────── */
.hero {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  height: 100svh;
}

/* ── Slider ── */
.slider {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.slide {
  position: absolute;
  inset: 0;
  z-index: 0;
  clip-path: inset(0 100% 0 0);
  will-change: clip-path;
}

.slide img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  pointer-events: none;
  user-select: none;
}

/* ── Overlay ── */
.overlay {
  position: absolute;
  inset: 0;
  z-index: var(--z-overlay);
  background:
    linear-gradient(to right,  rgb(var(--c-dark) / 0.62) 0%, transparent 55%),
    linear-gradient(to top,    rgb(var(--c-dark) / 0.55) 0%, transparent 50%),
    linear-gradient(to bottom, rgb(var(--c-dark) / 0.35) 0%, transparent 30%);
  pointer-events: none;
}

/* ── Content ── */
.hero-content {
  position: absolute;
  bottom: 36px;
  left: var(--px);
  z-index: var(--z-content);
  opacity: 0;
  /* delay matches .navbar animation in Navbar.astro (3.2s) */
  animation: riseIn 1s var(--ease-spring) 3.2s forwards;
}

.eyebrow {
  margin-bottom: 10px;
  color: rgb(var(--c-white) / 0.65);
  font-weight: 300;
  font-size: 12px;
  font-style: italic;
  letter-spacing: 0.08em;
}

.title {
  color: rgb(var(--c-white));
  font-weight: 700;
  font-size: clamp(58px, 7.8vw, 110px);
  letter-spacing: -0.03em;
  line-height: 0.94;
  text-transform: uppercase;
}

/* ── Scroll hint ── */
.scroll-hint {
  position: absolute;
  right: var(--px);
  bottom: 36px;
  z-index: var(--z-content);
  opacity: 0;
  color: rgb(var(--c-white) / 0.45);
  font-weight: 400;
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  animation: riseIn 0.7s ease 3.7s forwards;
}

/* ─────────────────────────────────
   RESPONSIVE
───────────────────────────────── */
@media (max-width: 768px) {
  .loader-inner {
    gap: 16px;
  }

  .loader-logo {
    font-size: 14px;
  }

  .loader-track {
    width: 120px;
  }

  .loader-label {
    font-size: 8px;
  }

  .hero-content {
    bottom: 24px;
  }

  .eyebrow {
    font-size: 10px;
    margin-bottom: 8px;
  }

  .title {
    font-size: clamp(48px, 12vw, 80px);
    line-height: 0.9;
  }

  .scroll-hint {
    bottom: 24px;
    font-size: 8px;
  }
}

@media (max-width: 480px) {
  .loader-inner {
    gap: 12px;
  }

  .loader-logo {
    font-size: 12px;
  }

  .loader-track {
    width: 100px;
  }

  .loader-fill {
    animation-duration: 1.4s;
  }

  .loader-label {
    font-size: 7px;
  }

  .hero-content {
    bottom: 20px;
  }

  .eyebrow {
    font-size: 9px;
    margin-bottom: 6px;
  }

  .title {
    font-size: clamp(36px, 14vw, 60px);
  }

  .scroll-hint {
    bottom: 20px;
    font-size: 7px;
  }
}

@media (max-width: 360px) {
  .loader-inner {
    gap: 10px;
  }

  .loader-logo {
    font-size: 11px;
  }

  .loader-track {
    width: 88px;
  }

  .loader-label {
    font-size: 6px;
  }

  .hero-content {
    bottom: 16px;
  }

  .eyebrow {
    font-size: 8px;
    margin-bottom: 5px;
  }

  .title {
    font-size: clamp(30px, 15vw, 48px);
  }

  .scroll-hint {
    display: none;
  }
}

/* ─────────────────────────────────
   MOTION PREFERENCE
───────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .loader-logo,
  .loader-track,
  .loader-label,
  .hero-content,
  .scroll-hint {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .loader-fill {
    animation: none;
    width: 100%;
  }

  .loader {
    transition: none;
  }
}
</style>

<script>
  // ── Timing constants (JS values must stay in sync with CSS animation delays) ──
  const SLIDE_DURATION = 1600;        // clip-path transition duration (ms)
  const SLIDE_EASE     = 'cubic-bezier(0.76, 0, 0.24, 1)';
  const AUTO_DELAY     = 7000;        // ms between auto-advances
  const LOADER_OUT_AT  = 2900;        // ms — after loader fill bar completes (~1s + 1.8s)
  const AUTO_START_AT  = 3800;        // ms — after hero content has risen in (~3.2s)

  function initHero(): void {
    const loader   = document.getElementById('loader');
    const slider   = document.getElementById('slider');

    if (!loader || !slider) return;

    const slideEls = Array.from(slider.querySelectorAll<HTMLElement>('.slide'));
    if (slideEls.length === 0) return;

    let current   = 0;
    let animating = false;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    // Set initial state: first slide visible, rest hidden
    slideEls.forEach((s, i) => {
      s.style.transition = 'none';
      s.style.clipPath   = i === 0 ? 'inset(0 0% 0 0)' : 'inset(0 100% 0 0)';
      s.style.zIndex     = i === 0 ? '1' : '0';
    });

    function goTo(next: number): void {
      if (animating || next === current) return;
      animating = true;

      const outEl = slideEls[current];
      const inEl  = slideEls[next];

      // Outgoing stays fully visible underneath
      outEl.style.transition = 'none';
      outEl.style.clipPath   = 'inset(0 0% 0 0)';
      outEl.style.zIndex     = '1';

      // Incoming starts hidden, on top
      inEl.style.transition  = 'none';
      inEl.style.clipPath    = 'inset(0 100% 0 0)';
      inEl.style.zIndex      = '2';

      // Force reflow so transition fires correctly
      inEl.getBoundingClientRect();

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          inEl.style.transition = `clip-path ${SLIDE_DURATION}ms ${SLIDE_EASE}`;
          inEl.style.clipPath   = 'inset(0 0% 0 0)';
          current = next;

          setTimeout(() => {
            outEl.style.transition = 'none';
            outEl.style.clipPath   = 'inset(0 100% 0 0)';
            outEl.style.zIndex     = '0';
            inEl.style.zIndex      = '1';
            animating = false;
          }, SLIDE_DURATION + 60);
        });
      });
    }

    function startAuto(): void {
      if (autoTimer) clearInterval(autoTimer);
      autoTimer = setInterval(
        () => goTo((current + 1) % slideEls.length),
        AUTO_DELAY,
      );
    }

    function stopAuto(): void {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    // Fade out loader after fill bar completes
    const loaderTimer = setTimeout(() => {
      loader.classList.add('fade-out');
    }, LOADER_OUT_AT);

    // Start auto-advance after hero content has animated in
    const startTimer = setTimeout(startAuto, AUTO_START_AT);

    // Cleanup on View Transition swap
    document.addEventListener('astro:before-swap', () => {
      clearTimeout(loaderTimer);
      clearTimeout(startTimer);
      stopAuto();
    }, { once: true });
  }

  // Run immediately (Astro scripts are deferred — DOM is ready)
  initHero();

  // Re-run after View Transitions (if enabled)
  document.addEventListener('astro:after-swap', initHero);
</script>
