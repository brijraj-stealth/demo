<section class="process-section" aria-labelledby="process-heading">

  <!-- Top image grid — padded portrait cards -->
  <div class="process-images">
    <div class="process-img-wrap">
      <img src="/asset 3.avif" alt="OURA & CO. Studio" loading="lazy" decoding="async" draggable="false" />
    </div>
    <div class="process-img-wrap">
      <img src="/asset 4.avif" alt="Interior project" loading="lazy" decoding="async" draggable="false" />
    </div>
  </div>

  <!-- Content area -->
  <div class="process-content">

    <!-- Left column -->
    <div class="process-left">
      <div class="process-left-top">
        <span class="process-label">&#8226; Stages</span>
        <h2 id="process-heading" class="process-heading">HOW WE<br/>WORK</h2>
      </div>
      <div class="process-left-img">
        <img src="/asset 12.avif" alt="Design process" loading="lazy" decoding="async" draggable="false" />
      </div>
    </div>

    <!-- Right column -->
    <div class="process-right">
      <p class="process-intro">We guide our clients through every stage of the project, ensuring clarity, transparency, and confidence from concept to completion</p>

      <div class="process-steps">

        <div class="process-step">
          <h3 class="step-title">Brief &amp; Analysis</h3>
          <p class="step-desc">We begin with an in-depth discussion to understand the client's lifestyle, preferences, and functional needs. This stage includes spatial analysis, reference studies, and defining the overall direction of the project.</p>
        </div>

        <div class="process-step">
          <h3 class="step-title">Concept Development</h3>
          <p class="step-desc">Based on the collected insights, we create a cohesive design concept. This includes moodboards, color palettes, layout solutions, and visual references that define the atmosphere and character of the future interior.</p>
        </div>

        <div class="process-step">
          <h3 class="step-title">Design Documentation</h3>
          <p class="step-desc">At this stage, we develop detailed design documentation, including drawings, specifications, and material selections. Every element is carefully considered to ensure accuracy, feasibility, and design integrity.</p>
        </div>

        <div class="process-step">
          <h3 class="step-title">Implementation &amp; Support</h3>
          <p class="step-desc">We support the project during realization, coordinating with contractors and suppliers. Author supervision ensures that the final result fully reflects the approved design concept.</p>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .process-section {
    --text:   #f0ece4;
    --muted:  rgba(240, 236, 228, 0.45);
    --border: rgba(240, 236, 228, 0.12);

    background: #000;
    width: 100%;
  }

  /* ── Top image grid ── */
  .process-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    padding: var(--py) var(--px) 0;
  }

  .process-img-wrap {
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .process-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .process-img-wrap:hover img {
    transform: scale(1.04);
  }

  /* ── Content area ── */
  .process-content {
    display: grid;
    grid-template-columns: 36% 1fr;
    padding: 52px var(--px) var(--py);
    gap: 56px;
  }

  /* ── Left ── */
  .process-left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .process-left-top {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .process-label {
    font-size: 10px;
    letter-spacing: 0.07em;
    color: var(--muted);
    font-weight: 400;
    text-transform: uppercase;
  }

  .process-heading {
    font-size: clamp(40px, 5.2vw, 78px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.92;
    color: var(--text);
    text-transform: uppercase;
  }

  .process-left-img {
    height: clamp(160px, 18vw, 240px);
    overflow: hidden;
    margin-top: 32px;
  }

  .process-left-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .process-left-img:hover img {
    transform: scale(1.05);
  }

  /* ── Right ── */
  .process-right {
    display: flex;
    flex-direction: column;
  }

  .process-intro {
    font-size: 14px;
    line-height: 1.7;
    color: var(--text);
    font-weight: 400;
    text-align: justify;
    margin-bottom: 40px;
    max-width: 56ch;
  }

  /* ── Steps ── */
  .process-steps {
    display: flex;
    flex-direction: column;
  }

  .process-step {
    display: grid;
    grid-template-columns: 195px 1fr;
    gap: 28px;
    padding: 20px 0;
    border-top: 1px solid var(--border);
  }

  .process-step:last-child {
    border-bottom: 1px solid var(--border);
  }

  .step-title {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text);
    padding-top: 1px;
  }

  .step-desc {
    font-size: 11px;
    line-height: 1.75;
    color: var(--muted);
    font-weight: 400;
  }

  /* ── 1440px ── */
  @media (max-width: 1440px) {
    .process-images {
      gap: 14px;
    }

    .process-content {
      gap: 52px;
    }
  }

  /* ── 1024px ── */
  @media (max-width: 1024px) {
    .process-images {
      gap: 12px;
    }

    .process-content {
      padding-top: 44px;
      gap: 44px;
    }

    .process-step {
      grid-template-columns: 160px 1fr;
      gap: 20px;
    }
  }

  /* ── 768px ── */
  @media (max-width: 768px) {
    .process-images {
      gap: 10px;
    }

    .process-content {
      grid-template-columns: 1fr;
      padding-top: 36px;
      gap: 32px;
    }

    .process-left {
      flex-direction: row;
      align-items: flex-end;
      gap: 24px;
    }

    .process-left-top {
      flex: 1;
    }

    .process-left-img {
      width: 36%;
      flex-shrink: 0;
      height: clamp(120px, 25vw, 180px);
      margin-top: 0;
    }

    .process-intro {
      font-size: 13px;
      max-width: 100%;
      margin-bottom: 32px;
    }

    .process-step {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 16px 0;
    }
  }

  /* ── 480px ── */
  @media (max-width: 480px) {
    .process-images {
      gap: 8px;
    }

    .process-content {
      padding-top: 28px;
      gap: 24px;
    }

    .process-left {
      flex-direction: column;
      align-items: flex-start;
    }

    .process-left-img {
      width: 55%;
      height: clamp(120px, 36vw, 200px);
      margin-top: 0;
    }

    .process-heading {
      font-size: clamp(34px, 10vw, 56px);
    }

    .process-intro {
      font-size: 12px;
      margin-bottom: 24px;
      text-align: left;
    }

    .process-step {
      padding: 14px 0;
      gap: 6px;
    }

    .step-title {
      font-size: 11px;
    }

    .step-desc {
      font-size: 10px;
      line-height: 1.7;
    }
  }

  /* ── 360px ── */
  @media (max-width: 360px) {
    .process-images {
      gap: 6px;
    }

    .process-content {
      padding-top: 24px;
      gap: 20px;
    }

    .process-label {
      font-size: 9px;
    }

    .process-heading {
      font-size: clamp(28px, 12vw, 44px);
    }

    .process-left-img {
      width: 60%;
      height: clamp(100px, 38vw, 160px);
    }

    .process-intro {
      font-size: 11px;
      margin-bottom: 20px;
    }

    .process-step {
      padding: 12px 0;
      gap: 5px;
    }

    .step-title {
      font-size: 10px;
    }

    .step-desc {
      font-size: 9px;
      line-height: 1.65;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .process-img-wrap img,
    .process-left-img img {
      transition: none;
    }
  }
</style>
