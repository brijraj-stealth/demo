---
interface ContactAction {
  label:  string;
  detail: string;
  href?:  string;
}

interface Props {
  heading?:   string;
  body?:      string;
  brandName?: string;
  intro?:     string;
  actions?:   ContactAction[];
}

const {
  heading   = 'GOT A SPACE WORTH DESIGNING?',
  body      = ' is open to new projects and bold visions. Write to us — and we will turn your space into a feeling.',
  brandName = 'OURA & CO.',
  intro     = 'Every project begins with a <strong>single conversation</strong>. Your vision can become the <strong>impetus</strong> that leads to a new space, a new aesthetic, a new experience. We are always available to <strong>hear from you</strong>.',
  actions   = [
    { label: 'BOOK A CALL',  detail: '+91 98765 43210',      href: 'tel:+919876543210' },
    { label: 'EMAIL US',     detail: 'studio@ouraandco.com', href: 'mailto:studio@ouraandco.com' },
    { label: 'MESSAGE US',   detail: 'DM us on Instagram',   href: '#' },
  ],
} = Astro.props;
---

<section class="contact-section" aria-labelledby="contact-heading">
  <div class="contact-grid">

    <!-- ── Left ── -->
    <div class="contact-left">
      <h2 id="contact-heading" class="contact-heading">{heading}</h2>
      <p class="contact-body">
        <span class="contact-brand">{brandName}</span>{body}
      </p>
    </div>

    <!-- ── Right ── -->
    <div class="contact-right">
      <p class="contact-intro" set:html={intro} />

      <ul class="contact-actions" role="list">
        {actions.map((action, i) => (
          <li class="contact-item">
            <button
              class="contact-toggle"
              aria-expanded="false"
              aria-controls={`contact-panel-${i}`}
            >
              <span class="contact-label">{action.label}</span>
              <span class="contact-icon" aria-hidden="true">+</span>
            </button>

            <div
              id={`contact-panel-${i}`}
              class="contact-panel"
              role="region"
              aria-labelledby={`contact-panel-${i}`}
            >
              <div class="contact-panel-inner">
                {action.href
                  ? <a href={action.href} class="contact-detail-link">{action.detail}</a>
                  : <span class="contact-detail-text">{action.detail}</span>
                }
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
/* ─────────────────────────────────
   DESIGN TOKENS
───────────────────────────────── */
.contact-section {
  --text:        #f0ebe4;
  --bg:          #0c0a08;
  --accent:      #c96444;
  --muted:       rgb(240 235 228 / 0.40);
  --border:      rgb(240 235 228 / 0.10);
  --ease-spring: cubic-bezier(0.22, 1, 0.36, 1);
  --ease-in:     cubic-bezier(0.4, 0, 0.2, 1);
}

/* ─────────────────────────────────
   SECTION
───────────────────────────────── */
.contact-section {
  display: flex;
  align-items: center;
  width: 100%;
  min-height: 100svh;
  padding: 100px 60px;
  background: var(--bg);
}

/* ─────────────────────────────────
   GRID
───────────────────────────────── */
.contact-grid {
  display: grid;
  grid-template-columns: 45fr 55fr;
  gap: 80px;
  align-items: start;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
}

/* ─────────────────────────────────
   LEFT COLUMN
───────────────────────────────── */
.contact-left {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.contact-heading {
  color: var(--text);
  font-weight: 700;
  font-size: clamp(32px, 4.5vw, 65px);
  letter-spacing: -0.04em;
  line-height: 1;
  text-transform: uppercase;
}

.contact-body {
  color: var(--text);
  font-weight: 400;
  font-size: clamp(14px, 1.5vw, 18px);
  line-height: 1.6;
  max-width: 38ch;
}

.contact-brand {
  font-weight: 600;
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────
   RIGHT COLUMN
───────────────────────────────── */
.contact-right {
  display: flex;
  flex-direction: column;
  gap: 48px;
  padding-top: 8px;
}

.contact-intro {
  color: var(--muted);
  font-weight: 400;
  font-size: 13px;
  line-height: 1.75;
  max-width: 46ch;
}

.contact-intro :global(strong) {
  color: var(--text);
  font-weight: 500;
}

/* ─────────────────────────────────
   ACCORDION
───────────────────────────────── */
.contact-actions {
  display: flex;
  flex-direction: column;
  list-style: none;
  border-top: 1px solid var(--border);
}

.contact-item {
  border-bottom: 1px solid var(--border);
}

/* Toggle button — reset all button defaults */
.contact-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 20px 0;
  background: none;
  border: none;
  cursor: pointer;
  user-select: none;
}

.contact-label {
  color: var(--text);
  font-weight: 400;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  transition: color 0.3s var(--ease-in);
}

.contact-icon {
  color: var(--text);
  font-size: 18px;
  font-weight: 300;
  line-height: 1;
  transition:
    transform 0.42s var(--ease-spring),
    color     0.3s var(--ease-in);
}

.contact-toggle:hover .contact-label,
.contact-toggle:hover .contact-icon {
  color: var(--accent);
}

/* ── Panel — grid-template-rows trick for height: auto animation ── */
.contact-panel {
  display: grid;
  grid-template-rows: 0fr;           /* collapsed */
  transition: grid-template-rows 0.42s var(--ease-spring);
}

.contact-panel.is-open {
  grid-template-rows: 1fr;           /* expanded */
}

/* min-height: 0 is required — without it 0fr won't collapse the child */
.contact-panel-inner {
  overflow: hidden;
  min-height: 0;
}

.contact-detail-link,
.contact-detail-text {
  display: block;
  padding: 4px 0 20px;
  color: var(--muted);
  font-weight: 400;
  font-size: 12px;
  letter-spacing: 0.06em;
  text-decoration: none;
  transition: color 0.3s var(--ease-in);
}

.contact-detail-link:hover {
  color: var(--accent);
}

/* Icon rotates when panel is open — driven by aria-expanded on the button */
.contact-toggle[aria-expanded="true"] .contact-icon {
  transform: rotate(45deg);
}

/* ─────────────────────────────────
   RESPONSIVE
───────────────────────────────── */
@media (max-width: 1024px) {
  .contact-section {
    padding: 80px 40px;
  }

  .contact-grid {
    gap: 60px;
  }

  .contact-heading {
    font-size: clamp(24px, 3.5vw, 55px);
  }
}

@media (max-width: 768px) {
  .contact-section {
    padding: 70px 24px;
    min-height: auto;
  }

  .contact-grid {
    grid-template-columns: 1fr;
    gap: 52px;
  }

  .contact-left {
    gap: 28px;
  }

  .contact-heading {
    font-size: clamp(20px, 5vw, 40px);
  }

  .contact-body,
  .contact-intro {
    max-width: 100%;
  }
}

@media (max-width: 480px) {
  .contact-section {
    padding: 60px 20px;
  }

  .contact-left {
    gap: 24px;
  }

  .contact-right {
    gap: 36px;
  }

  .contact-heading {
    font-size: clamp(16px, 6vw, 30px);
  }

  .contact-toggle {
    padding: 18px 0;
  }
}

/* ─────────────────────────────────
   MOTION PREFERENCE
───────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .contact-panel {
    transition: none;
  }

  .contact-icon,
  .contact-label,
  .contact-detail-link {
    transition: none;
  }
}
</style>

<script>
  function initAccordion(): void {
    const toggles = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.contact-toggle')
    );

    if (!toggles.length) return;

    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const panelId = toggle.getAttribute('aria-controls')!;
        const panel   = document.getElementById(panelId);
        if (!panel) return;

        const isOpen = toggle.getAttribute('aria-expanded') === 'true';

        if (isOpen) {
          // Close this panel
          toggle.setAttribute('aria-expanded', 'false');
          panel.classList.remove('is-open');
        } else {
          // Close every other open panel first
          toggles.forEach(other => {
            if (other === toggle) return;
            const otherId    = other.getAttribute('aria-controls')!;
            const otherPanel = document.getElementById(otherId);
            other.setAttribute('aria-expanded', 'false');
            otherPanel?.classList.remove('is-open');
          });

          // Open this one
          toggle.setAttribute('aria-expanded', 'true');
          panel.classList.add('is-open');
        }
      });
    });
  }

  // DOM is always ready in Astro deferred scripts
  initAccordion();

  // Re-init after View Transitions
  document.addEventListener('astro:after-swap', initAccordion);
</script>
