---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Works from '../components/Works.astro';
---

<Layout>
  <div class="sticky-hero">
    <Hero />
  </div>
  <div class="scroll-content">
    <Works />
  </div>
</Layout>

<style>
  .sticky-hero {
    position: sticky;
    top: 0;
    height: 100svh;
    z-index: 0;
  }

  .scroll-content {
    position: relative;
    z-index: 1;
  }
</style>
